<Window x:Class="HolaAI.Windows.SettingsWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Hola-AI Settings"
        Width="560"
        Height="640"
        WindowStartupLocation="CenterOwner"
        ResizeMode="NoResize"
        Loaded="Window_OnLoaded">
    <DockPanel>
        <!-- Save / Cancel buttons at bottom -->
        <StackPanel DockPanel.Dock="Bottom" Orientation="Horizontal"
                    HorizontalAlignment="Right" Margin="0,8,12,12">
            <Button Width="90" Height="32" Margin="0,0,8,0" IsCancel="True" Content="Cancel" />
            <Button Width="90" Height="32" IsDefault="True" Click="SaveButton_OnClick" Content="Save" />
        </StackPanel>

        <TabControl Margin="8,8,8,0">
            <!-- General Tab -->
            <TabItem Header="General">
                <StackPanel Margin="12">
                    <TextBlock Text="Transcription Language" FontWeight="SemiBold" Margin="0,0,0,4" />
                    <ComboBox x:Name="LanguageCombo" Height="28" />

                    <CheckBox x:Name="CodeSwitchingCheck" Margin="0,12,0,0"
                              Content="Code-Switching Mode (mixed languages)"
                              Checked="CodeSwitchingCheck_Changed" Unchecked="CodeSwitchingCheck_Changed" />
                    <TextBlock Text="When enabled, language selection is ignored and the system auto-detects language switches."
                               FontSize="11" Foreground="Gray" Margin="20,2,0,0" TextWrapping="Wrap" />

                    <CheckBox x:Name="LLMEnhancementCheck" Margin="0,12,0,0"
                              Content="Enable LLM text enhancement (punctuation, capitalization, self-correction)" />

                    <CheckBox x:Name="ShowOverlayCheck" Margin="0,12,0,0"
                              Content="Show overlay on startup" IsChecked="True" />

                    <TextBlock Text="Keyboard Shortcuts" FontWeight="SemiBold" Margin="0,20,0,4" />
                    <TextBlock Text="Ctrl+Shift+D — Start/Stop dictation" FontSize="12" Foreground="Gray" />
                    <TextBlock Text="Ctrl+Shift+C — Toggle prompt mode" FontSize="12" Foreground="Gray" />
                </StackPanel>
            </TabItem>

            <!-- API Tab -->
            <TabItem Header="API">
                <ScrollViewer VerticalScrollBarVisibility="Auto">
                    <StackPanel Margin="12">
                        <!-- STT Provider -->
                        <TextBlock Text="Transcription (STT)" FontWeight="SemiBold" FontSize="14" />
                        <Grid Margin="0,6,0,0">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="80" />
                                <ColumnDefinition Width="*" />
                            </Grid.ColumnDefinitions>
                            <Grid.RowDefinitions>
                                <RowDefinition Height="Auto" />
                                <RowDefinition Height="Auto" />
                            </Grid.RowDefinitions>
                            <TextBlock Text="Provider" VerticalAlignment="Center" />
                            <ComboBox x:Name="SttProviderCombo" Grid.Column="1" Height="26"
                                      SelectionChanged="SttProvider_Changed" />
                            <TextBlock Text="Model" Grid.Row="1" VerticalAlignment="Center" Margin="0,6,0,0" />
                            <TextBox x:Name="SttModelBox" Grid.Row="1" Grid.Column="1" Height="26" Margin="0,6,0,0"
                                     VerticalContentAlignment="Center" />
                        </Grid>
                        <TextBlock Text="Groq uses native Whisper API (fastest). OpenRouter uses audio via chat completions."
                                   FontSize="11" Foreground="Gray" Margin="0,4,0,0" TextWrapping="Wrap" />

                        <!-- Dictation LLM -->
                        <TextBlock Text="Text Cleanup (Dictation)" FontWeight="SemiBold" FontSize="14" Margin="0,16,0,0" />
                        <Grid Margin="0,6,0,0">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="80" />
                                <ColumnDefinition Width="*" />
                            </Grid.ColumnDefinitions>
                            <Grid.RowDefinitions>
                                <RowDefinition Height="Auto" />
                                <RowDefinition Height="Auto" />
                            </Grid.RowDefinitions>
                            <TextBlock Text="Provider" VerticalAlignment="Center" />
                            <ComboBox x:Name="DictationLLMProviderCombo" Grid.Column="1" Height="26"
                                      SelectionChanged="DictationLLMProvider_Changed" />
                            <TextBlock Text="Model" Grid.Row="1" VerticalAlignment="Center" Margin="0,6,0,0" />
                            <TextBox x:Name="DictationLLMModelBox" Grid.Row="1" Grid.Column="1" Height="26" Margin="0,6,0,0"
                                     VerticalContentAlignment="Center" />
                        </Grid>
                        <TextBlock Text="Fast model for punctuation, capitalization, and self-correction cleanup."
                                   FontSize="11" Foreground="Gray" Margin="0,4,0,0" TextWrapping="Wrap" />

                        <!-- Prompt LLM -->
                        <TextBlock Text="Prompt Enhancement" FontWeight="SemiBold" FontSize="14" Margin="0,16,0,0" />
                        <Grid Margin="0,6,0,0">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="80" />
                                <ColumnDefinition Width="*" />
                            </Grid.ColumnDefinitions>
                            <Grid.RowDefinitions>
                                <RowDefinition Height="Auto" />
                                <RowDefinition Height="Auto" />
                            </Grid.RowDefinitions>
                            <TextBlock Text="Provider" VerticalAlignment="Center" />
                            <ComboBox x:Name="PromptLLMProviderCombo" Grid.Column="1" Height="26"
                                      SelectionChanged="PromptLLMProvider_Changed" />
                            <TextBlock Text="Model" Grid.Row="1" VerticalAlignment="Center" Margin="0,6,0,0" />
                            <TextBox x:Name="PromptModelBox" Grid.Row="1" Grid.Column="1" Height="26" Margin="0,6,0,0"
                                     VerticalContentAlignment="Center" />
                        </Grid>
                        <TextBlock Text="More capable model for translating and rewriting prompts to English."
                                   FontSize="11" Foreground="Gray" Margin="0,4,0,0" TextWrapping="Wrap" />

                        <!-- API Keys -->
                        <TextBlock Text="API Keys" FontWeight="SemiBold" FontSize="14" Margin="0,20,0,0" />
                        <TextBlock Text="Keys are stored locally. Only keys for providers you use are required."
                                   FontSize="11" Foreground="Gray" Margin="0,2,0,8" TextWrapping="Wrap" />

                        <Grid>
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="80" />
                                <ColumnDefinition Width="*" />
                            </Grid.ColumnDefinitions>
                            <Grid.RowDefinitions>
                                <RowDefinition Height="Auto" />
                                <RowDefinition Height="Auto" />
                                <RowDefinition Height="Auto" />
                            </Grid.RowDefinitions>

                            <TextBlock Text="Groq" VerticalAlignment="Center" />
                            <PasswordBox x:Name="GroqKeyBox" Grid.Column="1" Height="26"
                                         VerticalContentAlignment="Center" />

                            <TextBlock Text="Cerebras" Grid.Row="1" VerticalAlignment="Center" Margin="0,6,0,0" />
                            <PasswordBox x:Name="CerebrasKeyBox" Grid.Row="1" Grid.Column="1" Height="26"
                                         Margin="0,6,0,0" VerticalContentAlignment="Center" />

                            <TextBlock Text="OpenRouter" Grid.Row="2" VerticalAlignment="Center" Margin="0,6,0,0" />
                            <PasswordBox x:Name="OpenRouterKeyBox" Grid.Row="2" Grid.Column="1" Height="26"
                                         Margin="0,6,0,0" VerticalContentAlignment="Center" />
                        </Grid>
                    </StackPanel>
                </ScrollViewer>
            </TabItem>
        </TabControl>
    </DockPanel>
</Window>
